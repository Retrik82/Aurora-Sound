# Copy to .env for Docker or backend/.env for local backend development.

# AI keys. Keep MOCK_GENERATION=true if you want a full local demo without paid APIs.
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
SUNO_API_KEY=your_suno_api_key_here
MOCK_GENERATION=true

# Local no-Docker mode. true = backend runs jobs itself, no Redis/worker needed.
# false = use Dramatiq worker + Redis.
LOCAL_INLINE_JOBS=true

# Backend
DATABASE_URL=sqlite+aiosqlite:///./app.db
REDIS_URL=redis://localhost:6379/0
AUDIO_STORAGE_DIR=./storage/audio
SOUNDSCAPE_ASSETS_DIR=./assets/soundscape
BACKEND_PUBLIC_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
